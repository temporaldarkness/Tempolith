<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      SetSize="360 240"
                      MinSize="360 240">
    <BoxContainer Orientation="Vertical" Margin="10" VerticalExpand="True">
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
            <Label Text="{Loc 'savings-window-account-label'}" />
            <Control HorizontalExpand="True" />
            <Label Name="AccountLabel" />
        </BoxContainer>
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
            <Label Text="{Loc 'savings-window-savings-label'}" />
            <Control HorizontalExpand="True" />
            <Label Name="SavingsLabel" />
        </BoxContainer>
        <Control MinHeight="12" />
        <LineEdit Name="AmountEdit" PlaceHolder="{Loc 'savings-window-amount-placeholder'}" HorizontalExpand="True" />
        <Control MinHeight="12" />
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="10">
            <Button Name="ToSavingsButton" Text="{Loc 'savings-window-to-savings'}" HorizontalExpand="True" />
            <Button Name="ToAccountButton" Text="{Loc 'savings-window-to-account'}" HorizontalExpand="True" />
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
