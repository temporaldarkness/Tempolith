ghost-role-information-syndicate-operative-name = Syndicate Operative
ghost-role-information-syndicate-operative-description = An Omicron unit operative equipped to destabilize the sector's political balance.
ghost-role-information-syndicate-operative-rules =
    You are a [color=#c94242][bold]Syndicate Omicron operative[/bold][/color]. You are a true political trickster sent to provoke conflicts and undermine other factions' plans in the sector.
    Follow your Sergeant's orders, if one is present, and obey Syndicate command.
    You do not remember your previous life or anything you learned while you were a ghost.

ghost-role-information-syndicate-leader-name = Syndicate Squad Leader
ghost-role-information-syndicate-leader-description = An Omicron unit Sergeant responsible for coordinating political destabilization in the sector.
ghost-role-information-syndicate-leader-rules =
    You are the [color=#c94242][bold]Sergeant of Syndicate unit Omicron[/bold][/color]. You command true political tricksters sent to provoke conflicts and undermine other factions' plans in the sector.
    Direct the Omicron operatives under your command and obey Syndicate command.
    You do not remember your previous life or anything you learned while you were a ghost.
